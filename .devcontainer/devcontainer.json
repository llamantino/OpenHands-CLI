{
  "name": "OpenHands CLI Dev",
  "image": "mcr.microsoft.com/devcontainers/python:dev-3.12-trixie",
  "remoteUser": "vscode",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  }
}